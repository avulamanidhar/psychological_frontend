<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_splash">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="32dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹ Back"
            android:textColor="@color/desc_gray"
            android:textSize="18sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/titleHelpFaq"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="Help &amp; FAQ"
        android:textColor="@color/title_blue"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnBack" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/titleHelpFaq">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Question 1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <RelativeLayout android:id="@+id/q1" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toStartOf="@+id/ic1" android:layout_alignParentStart="true" android:text="Is MindGuard AI a replacement for therapy?" android:textColor="@color/title_blue" android:textSize="15sp" android:textStyle="bold" />
                        <ImageView android:id="@+id/ic1" android:layout_width="20dp" android:layout_height="20dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@android:drawable/arrow_down_float" app:tint="@color/desc_gray" />
                    </RelativeLayout>
                    <TextView android:id="@+id/a1" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingHorizontal="20dp" android:paddingBottom="20dp" android:text="No, MindGuard AI is a support tool, not a replacement for professional therapy. We recommend seeing a licensed professional for diagnosis and treatment." android:textColor="@color/desc_gray" android:textSize="14sp" android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Question 2 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <RelativeLayout android:id="@+id/q2" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toStartOf="@+id/ic2" android:layout_alignParentStart="true" android:text="How is my data protected?" android:textColor="@color/title_blue" android:textSize="15sp" android:textStyle="bold" />
                        <ImageView android:id="@+id/ic2" android:layout_width="20dp" android:layout_height="20dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@android:drawable/arrow_down_float" app:tint="@color/desc_gray" />
                    </RelativeLayout>
                    <TextView android:id="@+id/a2" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingHorizontal="20dp" android:paddingBottom="20dp" android:text="Your data is encrypted locally using the AES-256 standard. Only you can access your journal entries and mood history." android:textColor="@color/desc_gray" android:textSize="14sp" android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Question 3 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <RelativeLayout android:id="@+id/q3" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toStartOf="@+id/ic3" android:layout_alignParentStart="true" android:text="How does the AI detect patterns?" android:textColor="@color/title_blue" android:textSize="15sp" android:textStyle="bold" />
                        <ImageView android:id="@+id/ic3" android:layout_width="20dp" android:layout_height="20dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@android:drawable/arrow_down_float" app:tint="@color/desc_gray" />
                    </RelativeLayout>
                    <TextView android:id="@+id/a3" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingHorizontal="20dp" android:paddingBottom="20dp" android:text="The AI analyzes the frequency and keywords in your entries to identify recurring emotional states over time." android:textColor="@color/desc_gray" android:textSize="14sp" android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>